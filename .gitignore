# ---- Secrets (NEVER commit) ----
.env
.env.local
.env.*.local
*.pem
*.key
kaggle.json
service-account*.json

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/

# ---- Node / Next.js ----
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-error.log*
.pnp.*

# onnxruntime-web wasm runtime is copied from node_modules by scripts/copy-ort.mjs
# on predev/prebuild — derived, so regenerate rather than commit. (The YOLOv8 model
# frontend/public/models/best.onnx IS committed deliberately — see REMAINING_IMPLEMENTATION_PLAN Phase A.)
frontend/public/ort/

# Derived from the model bytes by scripts/cv-version.mjs on postinstall/predev/prebuild.
# Deliberately NOT committed: a checked-in copy could disagree with the .onnx actually
# present, which is precisely the untraceable model-identity problem it exists to solve.
frontend/lib/cv/model-version.json

# ---- Data (large, downloaded, not versioned) ----
data/raw/
# The comparables corpus IS versioned: the Phase-E cron appends to it and commits, so it
# must exist in a fresh checkout (a bare `data/processed/` dir-ignore silently broke that).
data/processed/*
!data/processed/comparables.csv
# price_history.csv is versioned for the same reason: the Phase-E cron appends every
# sighting and commits it. While it was ignored, the workflow's `git add` of it failed and
# the commit step aborted — so a successful scrape never actually pushed.
!data/processed/price_history.csv
*.parquet
*.csv.gz

# ---- Model weights (only final exported weights are committed deliberately) ----
*.pt
*.pth
runs/
wandb/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Local Claude Code dev config (per-machine, e.g. dev-server launch config) ----
.claude/
