# ---- Secrets (NEVER commit) ----
.env
.env.local
.env.*.local
*.pem
*.key
kaggle.json
service-account*.json

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/

# ---- Node / Next.js ----
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-error.log*
.pnp.*

# onnxruntime-web wasm runtime is copied from node_modules by scripts/copy-ort.mjs
# on predev/prebuild — derived, so regenerate rather than commit. (The YOLOv8 model
# frontend/public/models/best.onnx IS committed deliberately — see REMAINING_IMPLEMENTATION_PLAN Phase A.)
frontend/public/ort/

# ---- Data (large, downloaded, not versioned) ----
data/raw/
# The comparables corpus IS versioned: the Phase-E cron appends to it and commits, so it
# must exist in a fresh checkout (a bare `data/processed/` dir-ignore silently broke that).
data/processed/*
!data/processed/comparables.csv
*.parquet
*.csv.gz

# ---- Model weights (only final exported weights are committed deliberately) ----
*.pt
*.pth
runs/
wandb/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
