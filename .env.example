# ============================================================================
# AutoValuate Intelligence — environment variable TEMPLATE
# Copy to `.env` (gitignored) and fill in real values during local dev.
# In production, set these in each platform's env-var settings, never in code.
# ============================================================================

# ---- LLM providers (report-writing agent) ----
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq Console: https://console.groq.com/keys
GROQ_API_KEY=

# ---- Supabase (Postgres + pgvector + Auth + Storage) ----
# Project Settings -> API in the Supabase dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Direct Postgres connection string (Settings -> Database) for pgvector loads
SUPABASE_DB_URL=

# ---- CV (damage detector) ----
# Production scans run IN THE BROWSER (frontend/lib/cv-browser.ts); photos are never
# uploaded. This switch only enables the server-side detector for callers that POST
# photos directly. The remote CV Space was removed — it was a silently divergent
# second implementation. See docs/CV_INFERENCE_SPEC.md.
ENABLE_LOCAL_CV=

# ---- Backend API (Render) base URL, consumed by the frontend ----
BACKEND_API_URL=

# ---- Frontend (Next.js on Vercel) — NEXT_PUBLIC_* are exposed to the browser ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=

# ---- CI/CD deploy hooks (stored as GitHub Actions secrets, not used locally) ----
RENDER_DEPLOY_HOOK=
VERCEL_TOKEN=
